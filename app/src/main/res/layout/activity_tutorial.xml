<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:stretchColumns="*"
    android:padding="20dp"
    android:background="@color/ingame_bg_color">

    <TableRow android:layout_height="wrap_content">
        <LinearLayout
            android:layout_span="3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/tutorial_back_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="35dp"
                android:text="&lt;"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                style="@style/Widget.AppCompat.Button.Borderless"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="center"
                android:text="TUTORIAL"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </TableRow>

    <TableRow
        android:layout_height="wrap_content">

        <!-- Step counter -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_height="wrap_content"
                style="@style/score_cell_style"
                android:orientation="vertical">
                <TextView
                    style="@style/score_title_style"
                    android:text="STEP"/>
                <TextView
                    android:id="@+id/tutorial_step"
                    style="@style/score_style"
                    android:text="1/5"/>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                style="@style/undo_game_btn_style"
                android:id="@+id/tutorial_restart_btn"
                android:text="RESTART"/>

        </LinearLayout>

        <!-- Score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_height="wrap_content"
                style="@style/score_cell_style"
                android:orientation="vertical">
                <TextView
                    style="@style/score_title_style"
                    android:text="SCORE"/>
                <TextView
                    android:id="@+id/tutorial_score"
                    style="@style/score_style"
                    android:text="0"/>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                style="@style/undo_game_btn_style"
                android:id="@+id/tutorial_skip_btn"
                android:text="SKIP"/>

        </LinearLayout>

    </TableRow>

    <!-- Instruction box -->
    <TableRow android:layout_height="wrap_content">
        <LinearLayout
            android:layout_span="3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_corners"
            android:backgroundTint="@color/game_panel_bg_color"
            android:padding="12dp"
            android:layout_marginVertical="8dp">

            <TextView
                android:id="@+id/tutorial_instruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:text="Welcome! Swipe tiles to merge matching numbers."/>

            <TextView
                android:id="@+id/tutorial_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="italic"
                android:layout_marginTop="4dp"
                android:text="Try swiping LEFT"/>

        </LinearLayout>
    </TableRow>

    <!-- Game grid -->
    <TableRow>
        <GridLayout
            android:id="@+id/tutorial_game_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_corners"
            android:backgroundTint="@color/game_panel_bg_color"
            android:padding="5dp"
            android:layout_weight="1"/>
    </TableRow>

    <!-- Toggle buttons -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_span="3"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/sound_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:drawableLeft="@drawable/ic_fas_volume_up"
                android:drawableTint="@color/white"
                android:drawablePadding="6dp"
                android:gravity="start|center_vertical"
                android:text="Sound"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/dark_mode_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:drawableLeft="@drawable/ic_fas_moon"
                android:drawableTint="@color/white"
                android:drawablePadding="6dp"
                android:gravity="start|center_vertical"
                android:text="Dark Mode"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>


    </TableRow>
    <TableRow>
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/animation_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:drawableStart="@drawable/ic_fas_star"
            android:drawableTint="@color/white"
            android:drawablePadding="6dp"
            android:gravity="start|center_vertical"
            android:text="Animation"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </TableRow>

</TableLayout>