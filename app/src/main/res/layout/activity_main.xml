<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_row="3"
    android:stretchColumns="*"
    android:id="@+id/main"
    android:padding="20dp"
    android:background="@color/ingame_bg_color">

    <TableRow
        android:layout_height="18sp"
        android:textStyle="bold">

        <TextView
            android:id="@+id/title"
            style="@style/title_style"
            android:text="2048"
            android:background="@drawable/rounded_corners"
            android:backgroundTint="@color/title_color"
            android:textColor="@color/white"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/col2"
            android:layout_width="fill_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/score_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/score_cell"
                    style="@style/score_cell_style"
                    android:orientation="vertical">

                    <TextView
                        style="@style/score_title_style"
                        android:text="SCORE"
                        android:id="@+id/score_title"/>

                    <TextView
                        android:text="520"
                        style="@style/score_style"
                        android:id="@+id/score"/>
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    style="@style/undo_game_btn_style"
                    android:id="@+id/new_btn"
                    android:text="NEW"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/col3"
            android:layout_width="fill_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/max_score_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/max_score_cell"
                    style="@style/score_cell_style"
                    android:orientation="vertical">

                    <TextView
                        style="@style/score_title_style"
                        android:text="BEST"
                        android:id="@+id/max_score_title"/>

                    <TextView
                        android:text="520"
                        style="@style/score_style"
                        android:id="@+id/max_score"/>
                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    style="@style/undo_game_btn_style"
                    android:id="@+id/undo_btn"
                    android:text="UNDO" />
            </LinearLayout>
        </LinearLayout>
    </TableRow>

    <TableRow>
        <TextView
            android:text="Sample tips, Sample tips, Sample tips, Sample tips"
            style="@style/tips_style"
            android:id="@+id/tips"
            android:layout_weight="1" />
    </TableRow>

    <TableRow>
        <GridLayout
            android:id="@+id/game_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_span="1"
            android:background="@drawable/rounded_corners"
            android:backgroundTint="@color/game_panel_bg_color"
            android:padding="5dp"
            android:layout_weight="1">
        </GridLayout>
    </TableRow>
    <TableRow>
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/view_stats_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="20dp"
            android:textSize="20sp"
            android:text="View Stats"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:background="@drawable/rounded_corners"
            android:backgroundTint="@color/undo_btn_color"
            />
    </TableRow>
    <TableRow>
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/menu_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="20dp"
            android:textSize="20sp"
            android:text="MENU"
            android:layout_weight="1"
            android:textColor="@color/white"
            android:background="@drawable/rounded_corners"
            android:backgroundTint="@color/undo_btn_color"
            android:layout_margin="0dp"
            />
    </TableRow>
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_span="3"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/sound_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:drawableLeft="@drawable/ic_fas_volume_up"
                android:drawableTint="@color/white"
                android:drawablePadding="6dp"
                android:gravity="start|center_vertical"
                android:text="Sound"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/dark_mode_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:drawableLeft="@drawable/ic_fas_moon"
                android:drawableTint="@color/white"
                android:drawablePadding="6dp"
                android:gravity="start|center_vertical"
                android:text="Dark Mode"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>


    </TableRow>
    <TableRow>
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/animation_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:drawableStart="@drawable/ic_fas_star"
        android:drawableTint="@color/white"
        android:drawablePadding="6dp"
        android:gravity="start|center_vertical"
        android:text="Animation"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"/>
    </TableRow>
</TableLayout>
