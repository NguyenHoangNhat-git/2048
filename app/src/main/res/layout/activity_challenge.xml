<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:stretchColumns="*"
    android:id="@+id/challenge_main"
    android:padding="20dp"
    android:background="@color/ingame_bg_color">

    <TableRow
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/challenge_title"
            style="@style/title_style"
            android:text="CHALLENGE MODE"
            android:background="@drawable/rounded_corners"
            android:backgroundTint="@color/title_color"
            android:textColor="@color/white"
            android:textSize="25sp"
            android:layout_weight="1"/>

        <!-- Countdown timer -->
        <LinearLayout
            android:layout_width="fill_parent"
            android:gravity="center"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <LinearLayout
                    style="@style/score_cell_style"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        style="@style/score_title_style"
                        android:text="TIME"/>
                    <TextView
                        android:id="@+id/countdown_timer"
                        style="@style/score_style"
                        android:text="3:00"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <androidx.appcompat.widget.AppCompatButton
                        style="@style/undo_game_btn_style"
                        android:id="@+id/challenge_new_btn"
                        android:text="NEW"/>
                    <androidx.appcompat.widget.AppCompatButton
                        style="@style/undo_game_btn_style"
                        android:id="@+id/challenge_back_btn"
                        android:text="Quit"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Target score + current score -->
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="match_parent"
            android:gravity="start"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <LinearLayout
                    style="@style/score_cell_style"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        style="@style/score_title_style"
                        android:text="SCORE"/>
                    <TextView
                        android:id="@+id/challenge_score"
                        style="@style/score_style"
                        android:text="0"/>
                </LinearLayout>
                <LinearLayout
                    style="@style/score_cell_style"
                    android:orientation="vertical"
                    android:layout_height="match_parent"
                    android:layout_marginTop="4dp">
                    <TextView
                        style="@style/score_title_style"
                        android:layout_height="wrap_content"
                        android:text="TARGET"/>
                    <TextView
                        android:id="@+id/challenge_target"
                        android:layout_height="wrap_content"
                        style="@style/score_style"
                        android:text="512"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </TableRow>

    <TableRow>
        <TextView
            android:id="@+id/challenge_tips"
            style="@style/tips_style"
            android:text="Reach the target score before time runs out!"
            android:layout_weight="1"/>
    </TableRow>

    <TableRow>
        <GridLayout
            android:id="@+id/challenge_game_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_corners"
            android:backgroundTint="@color/game_panel_bg_color"
            android:padding="5dp"
            android:layout_weight="1"/>
    </TableRow>

</TableLayout>